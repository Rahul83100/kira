{
  "name": "kira",
  "version": "1.0.0",
  "description": "Kira — open-source, self-hosted AI customer support & sales agent (RAG over your own data)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "worker": "node src/workers/embeddingWorker.js",
    "start:chat": "cd sandra-chat-api && node src/server.js",
    "start:dashboard": "cd dashboard && npx vite --port 5173",
    "start:all": "bash start-all.sh",
    "db:schema": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -f db/seed.sql"
  },
  "keywords": [
    "ai",
    "customer-support",
    "chatbot",
    "rag",
    "vector-search",
    "pgvector",
    "gemini",
    "self-hosted",
    "open-source",
    "support-agent"
  ],
