      "item": [
        {
          "name": "Upload PDF",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "if (pm.response.code === 201) {",
                  "  pm.test('Status code is 201 (file attached)', function () {",
                  "    pm.response.to.have.status(201);",
                  "  });",
                  "",
                  "  pm.test('Response has document_id and chunks_created', function () {",
                  "    pm.expect(json).to.have.property('document_id');",
                  "    pm.expect(json).to.have.property('chunks_created');",
                  "    pm.expect(json.message).to.eql('PDF processed successfully');",
                  "    pm.collectionVariables.set('documentId', json.document_id);",
                  "  });",
                  "} else if (pm.response.code === 400) {",
                  "  pm.test('Status code is 400 — no file attached (select a PDF in Body tab)', function () {",
                  "    pm.response.to.have.status(400);",
                  "  });",
                  "",
                  "  pm.test('Returns validation error for missing file', function () {",
                  "    pm.expect(json).to.have.property('error');",
                  "    pm.expect(json.error).to.include('No PDF file provided');",
                  "  });",
                  "} else {",
                  "  pm.test('Unexpected status code: ' + pm.response.code, function () {",
                  "    pm.expect.fail('Expected 201 (with file) or 400 (without file), got ' + pm.response.code);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
