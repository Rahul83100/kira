  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "sk_live_test_token_123",
      "type": "string"
    },
    {
      "key": "documentId",
      "value": "REPLACE_WITH_DOCUMENT_ID",
      "type": "string"
    }
  ],
