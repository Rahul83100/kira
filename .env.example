# ══════════════════════════════════════════════════════════════════════════════
# Kira — Environment configuration
# ══════════════════════════════════════════════════════════════════════════════
#   cp .env.example .env   then fill in the ONE required key below.
#   Never commit your real .env — it is gitignored.
# ══════════════════════════════════════════════════════════════════════════════

# ┌────────────────────────────────────────────────────────────────────────────┐
# │ REQUIRED — the only key you must set to run Kira with `docker compose up`     │
# └────────────────────────────────────────────────────────────────────────────┘

# Google Gemini API key — powers chat responses AND embeddings.
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ┌────────────────────────────────────────────────────────────────────────────┐
# │ DATABASE & REDIS                                                             │
# │ With `docker compose up` these are injected automatically — leave them be.   │
# │ Only set them if you run Kira WITHOUT Docker (e.g. against your own          │
# │ Postgres/Supabase + Redis/Upstash).                                          │
# └────────────────────────────────────────────────────────────────────────────┘
DATABASE_URL=postgresql://kira:kira_dev_password@localhost:5432/kira
REDIS_URL=redis://localhost:6379

# Optional: only if you host your database on Supabase and want to use its REST
# layer. Leave blank to use DATABASE_URL (plain Postgres) directly.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ┌────────────────────────────────────────────────────────────────────────────┐
# │ SERVER (sensible defaults — override only if you need to)                    │
# └────────────────────────────────────────────────────────────────────────────┘
PORT=3000
CHAT_PORT=3001
NODE_ENV=development
# Public base URL of your deployment (used for QR codes / standalone chat links).
PUBLIC_BASE_URL=http://localhost:3000
# Comma-separated list of origins allowed to call the API (CORS).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ┌────────────────────────────────────────────────────────────────────────────┐
# │ OPTIONAL INTEGRATIONS — everything below is OFF until you set it.            │
# │ Kira runs fine without any of these.                                         │
# └────────────────────────────────────────────────────────────────────────────┘

# Anthropic Claude — optional LLM fallback for the chat API.
ANTHROPIC_API_KEY=

# Resend — transactional email (signup OTP, lead alerts). Without it, signups
# are auto-verified locally and no emails are sent.
RESEND_API_KEY=
AUTH_EMAIL_FROM=Kira <onboarding@resend.dev>
ALERT_EMAIL_FROM=Kira Alerts <onboarding@resend.dev>
ALERT_EMAIL_TO=

# Firebase — optional Google sign-in for the dashboard. Without it, the
# dashboard uses email/password auth. Create a free project at firebase.google.com
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Backend Firebase project id (only needed for Remote Config prompt management).
FIREBASE_PROJECT_ID=

# Razorpay — optional payments/billing (commercial feature, off by default).
VITE_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Crawler limits (optional tuning).
MAX_CRAWL_PAGES=100
MAX_CRAWL_DEPTH=5

# Google Maps — optional location enrichment.
GOOGLE_MAPS_API_KEY=

# Admin endpoints secret (optional ops tooling).
ADMIN_SECRET_KEY=
